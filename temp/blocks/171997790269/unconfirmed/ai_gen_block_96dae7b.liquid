{% doc %}
  @prompt
    blog post, should be editorial layout
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-blog-post-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
    padding: {{ block.settings.vertical_spacing }}px 20px;
  }

  .ai-blog-post-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.content_max_width }}px;
    margin: 0 auto;
  }

  .ai-blog-post-meta-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 24px;
    font-size: 14px;
    color: {{ block.settings.meta_text_color }};
    flex-wrap: wrap;
  }

  .ai-blog-post-category-{{ ai_gen_id }} {
    display: inline-block;
    padding: 6px 12px;
    background-color: {{ block.settings.category_bg_color }};
    color: {{ block.settings.category_text_color }};
    border-radius: 4px;
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .ai-blog-post-date-{{ ai_gen_id }} {
    font-style: italic;
  }

  .ai-blog-post-author-{{ ai_gen_id }} {
    font-weight: 500;
  }

  .ai-blog-post-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    line-height: 1.2;
    margin: 0 0 24px;
    color: {{ block.settings.title_color }};
    font-weight: 700;
  }

  .ai-blog-post-excerpt-{{ ai_gen_id }} {
    font-size: {{ block.settings.excerpt_size }}px;
    line-height: 1.6;
    margin-bottom: 40px;
    color: {{ block.settings.excerpt_color }};
    font-style: italic;
    padding-left: 20px;
    border-left: 4px solid {{ block.settings.category_bg_color }};
  }

  .ai-blog-post-featured-image-{{ ai_gen_id }} {
    width: 100%;
    margin-bottom: 40px;
    border-radius: {{ block.settings.image_border_radius }}px;
    overflow: hidden;
  }

  .ai-blog-post-featured-image-{{ ai_gen_id }} img {
    width: 100%;
    height: auto;
    display: block;
  }

  .ai-blog-post-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 16 / 9;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: {{ block.settings.image_border_radius }}px;
  }

  .ai-blog-post-image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-blog-post-content-{{ ai_gen_id }} {
    font-size: {{ block.settings.body_size }}px;
    line-height: 1.8;
    color: {{ block.settings.body_color }};
  }

  .ai-blog-post-content-{{ ai_gen_id }} p {
    margin-bottom: 24px;
  }

  .ai-blog-post-content-{{ ai_gen_id }} h2 {
    font-size: {{ block.settings.body_size | times: 1.5 }}px;
    margin-top: 48px;
    margin-bottom: 16px;
    font-weight: 700;
    color: {{ block.settings.title_color }};
  }

  .ai-blog-post-content-{{ ai_gen_id }} h3 {
    font-size: {{ block.settings.body_size | times: 1.25 }}px;
    margin-top: 32px;
    margin-bottom: 12px;
    font-weight: 600;
    color: {{ block.settings.title_color }};
  }

  .ai-blog-post-content-{{ ai_gen_id }} ul,
  .ai-blog-post-content-{{ ai_gen_id }} ol {
    margin-bottom: 24px;
    padding-left: 32px;
  }

  .ai-blog-post-content-{{ ai_gen_id }} li {
    margin-bottom: 8px;
  }

  .ai-blog-post-content-{{ ai_gen_id }} a {
    color: {{ block.settings.link_color }};
    text-decoration: underline;
  }

  .ai-blog-post-content-{{ ai_gen_id }} a:hover {
    color: {{ block.settings.link_hover_color }};
  }

  .ai-blog-post-quote-{{ ai_gen_id }} {
    margin: 32px 0;
    padding: 24px 32px;
    background-color: {{ block.settings.quote_bg_color }};
    border-left: 4px solid {{ block.settings.category_bg_color }};
    font-style: italic;
    font-size: {{ block.settings.body_size | times: 1.1 }}px;
    color: {{ block.settings.body_color }};
  }

  .ai-blog-post-tags-{{ ai_gen_id }} {
    margin-top: 48px;
    padding-top: 32px;
    border-top: 1px solid {{ block.settings.divider_color }};
  }

  .ai-blog-post-tags-label-{{ ai_gen_id }} {
    font-size: 14px;
    font-weight: 600;
    margin-bottom: 12px;
    color: {{ block.settings.meta_text_color }};
  }

  .ai-blog-post-tags-list-{{ ai_gen_id }} {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .ai-blog-post-tag-{{ ai_gen_id }} {
    display: inline-block;
    padding: 6px 12px;
    background-color: {{ block.settings.tag_bg_color }};
    color: {{ block.settings.tag_text_color }};
    border-radius: 20px;
    font-size: 13px;
    text-decoration: none;
    transition: background-color 0.2s ease;
  }

  .ai-blog-post-tag-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.tag_hover_bg_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-blog-post-{{ ai_gen_id }} {
      padding: {{ block.settings.vertical_spacing | times: 0.6 }}px 16px;
    }

    .ai-blog-post-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.7 }}px;
    }

    .ai-blog-post-excerpt-{{ ai_gen_id }} {
      font-size: {{ block.settings.excerpt_size | times: 0.9 }}px;
      margin-bottom: 24px;
    }

    .ai-blog-post-content-{{ ai_gen_id }} {
      font-size: {{ block.settings.body_size | times: 0.95 }}px;
    }

    .ai-blog-post-content-{{ ai_gen_id }} h2 {
      font-size: {{ block.settings.body_size | times: 1.3 }}px;
      margin-top: 32px;
    }

    .ai-blog-post-content-{{ ai_gen_id }} h3 {
      font-size: {{ block.settings.body_size | times: 1.15 }}px;
      margin-top: 24px;
    }
  }
{% endstyle %}

<ai-blog-post-{{ ai_gen_id }} class="ai-blog-post-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <article class="ai-blog-post-container-{{ ai_gen_id }}">
    {% if block.settings.show_meta %}
      <div class="ai-blog-post-meta-{{ ai_gen_id }}">
        {% if block.settings.category != blank %}
          <span class="ai-blog-post-category-{{ ai_gen_id }}">{{ block.settings.category }}</span>
        {% endif %}
        {% if block.settings.show_date and block.settings.publish_date != blank %}
          <time class="ai-blog-post-date-{{ ai_gen_id }}" datetime="{{ block.settings.publish_date }}">
            {{ block.settings.publish_date | date: "%B %d, %Y" }}
          </time>
        {% endif %}
        {% if block.settings.show_author and block.settings.author != blank %}
          <span class="ai-blog-post-author-{{ ai_gen_id }}">By {{ block.settings.author }}</span>
        {% endif %}
      </div>
    {% endif %}

    {% if block.settings.title != blank %}
      <h1 class="ai-blog-post-title-{{ ai_gen_id }}">{{ block.settings.title }}</h1>
    {% endif %}

    {% if block.settings.excerpt != blank %}
      <div class="ai-blog-post-excerpt-{{ ai_gen_id }}">
        {{ block.settings.excerpt }}
      </div>
    {% endif %}

    {% if block.settings.featured_image %}
      <div class="ai-blog-post-featured-image-{{ ai_gen_id }}">
        <img
          src="{{ block.settings.featured_image | image_url: width: 1600 }}"
          alt="{{ block.settings.featured_image.alt | escape }}"
          loading="lazy"
          width="{{ block.settings.featured_image.width }}"
          height="{{ block.settings.featured_image.height }}"
        >
      </div>
    {% else %}
      <div class="ai-blog-post-image-placeholder-{{ ai_gen_id }}">
        {{ 'image' | placeholder_svg_tag }}
      </div>
    {% endif %}

    {% if block.settings.content != blank %}
      <div class="ai-blog-post-content-{{ ai_gen_id }}">
        {{ block.settings.content }}
      </div>
    {% endif %}

    {% if block.settings.show_quote and block.settings.quote != blank %}
      <div class="ai-blog-post-quote-{{ ai_gen_id }}">
        {{ block.settings.quote }}
      </div>
    {% endif %}

    {% if block.settings.show_tags and block.settings.tags != blank %}
      <div class="ai-blog-post-tags-{{ ai_gen_id }}">
        <div class="ai-blog-post-tags-label-{{ ai_gen_id }}">Tags</div>
        <div class="ai-blog-post-tags-list-{{ ai_gen_id }}">
          {% assign tags_array = block.settings.tags | split: ',' %}
          {% for tag in tags_array %}
            <span class="ai-blog-post-tag-{{ ai_gen_id }}">{{ tag | strip }}</span>
          {% endfor %}
        </div>
      </div>
    {% endif %}
  </article>
</ai-blog-post-{{ ai_gen_id }}>

<script>
  (function() {
    class AiBlogPost{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.setupAccessibility();
      }

      setupAccessibility() {
        const article = this.querySelector('article');
        if (article) {
          article.setAttribute('role', 'article');
        }
      }
    }

    customElements.define('ai-blog-post-{{ ai_gen_id }}', AiBlogPost{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Blog post",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "The Future of Sustainable Fashion"
    },
    {
      "type": "textarea",
      "id": "excerpt",
      "label": "Excerpt",
      "default": "Exploring how the fashion industry is transforming to meet the demands of conscious consumers and environmental responsibility."
    },
    {
      "type": "image_picker",
      "id": "featured_image",
      "label": "Featured image"
    },
    {
      "type": "richtext",
      "id": "content",
      "label": "Content",
      "default": "<p>The fashion industry stands at a crossroads. As consumers become increasingly aware of the environmental and social impact of their purchases, brands are being called to reimagine their entire approach to design, production, and distribution.</p><h2>A New Era of Transparency</h2><p>Today's consumers demand to know where their clothes come from, who made them, and under what conditions. This shift has forced brands to become more transparent about their supply chains and manufacturing processes.</p><h3>Key Changes in the Industry</h3><p>Several major developments are reshaping the landscape of sustainable fashion and creating new opportunities for brands that prioritize ethical practices.</p><ul><li>Increased use of organic and recycled materials</li><li>Investment in circular economy models</li><li>Greater transparency in supply chains</li><li>Focus on durability and timeless design</li></ul><p>As we move forward, the brands that thrive will be those that can balance style, quality, and sustainability creating pieces that consumers can feel good about wearing for years to come.</p>"
    },
    {
      "type": "checkbox",
      "id": "show_quote",
      "label": "Show quote",
      "default": true
    },
    {
      "type": "richtext",
      "id": "quote",
      "label": "Quote",
      "default": "<p>Sustainability is no longer a trend it is a fundamental shift in how we think about fashion and consumption.</p>"
    },
    {
      "type": "header",
      "content": "Metadata"
    },
    {
      "type": "checkbox",
      "id": "show_meta",
      "label": "Show metadata",
      "default": true
    },
    {
      "type": "text",
      "id": "category",
      "label": "Category",
      "default": "Fashion"
    },
    {
      "type": "checkbox",
      "id": "show_date",
      "label": "Show publish date",
      "default": true
    },
    {
      "type": "text",
      "id": "publish_date",
      "label": "Publish date",
      "default": "2026-04-15"
    },
    {
      "type": "checkbox",
      "id": "show_author",
      "label": "Show author",
      "default": true
    },
    {
      "type": "text",
      "id": "author",
      "label": "Author name",
      "default": "Editorial Team"
    },
    {
      "type": "checkbox",
      "id": "show_tags",
      "label": "Show tags",
      "default": true
    },
    {
      "type": "text",
      "id": "tags",
      "label": "Tags",
      "default": "Sustainability, Fashion, Trends, Innovation"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "range",
      "id": "content_max_width",
      "label": "Content max width",
      "min": 600,
      "max": 1000,
      "step": 50,
      "unit": "px",
      "default": 750
    },
    {
      "type": "range",
      "id": "vertical_spacing",
      "label": "Vertical spacing",
      "min": 20,
      "max": 100,
      "step": 10,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "image_border_radius",
      "label": "Image border radius",
      "min": 0,
      "max": 20,
      "step": 2,
      "unit": "px",
      "default": 8
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "title_size",
      "label": "Title size",
      "min": 24,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 42
    },
    {
      "type": "range",
      "id": "excerpt_size",
      "label": "Excerpt size",
      "min": 14,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 18
    },
    {
      "type": "range",
      "id": "body_size",
      "label": "Body size",
      "min": 14,
      "max": 22,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "body_color",
      "label": "Body text",
      "default": "#333333"
    },
    {
      "type": "color",
      "id": "excerpt_color",
      "label": "Excerpt",
      "default": "#555555"
    },
    {
      "type": "color",
      "id": "meta_text_color",
      "label": "Metadata",
      "default": "#666666"
    },
    {
      "type": "color",
      "id": "link_color",
      "label": "Link",
      "default": "#0066cc"
    },
    {
      "type": "color",
      "id": "link_hover_color",
      "label": "Link hover",
      "default": "#004499"
    },
    {
      "type": "color",
      "id": "category_bg_color",
      "label": "Category background",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "category_text_color",
      "label": "Category text",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "tag_bg_color",
      "label": "Tag background",
      "default": "#f0f0f0"
    },
    {
      "type": "color",
      "id": "tag_text_color",
      "label": "Tag text",
      "default": "#333333"
    },
    {
      "type": "color",
      "id": "tag_hover_bg_color",
      "label": "Tag hover background",
      "default": "#e0e0e0"
    },
    {
      "type": "color",
      "id": "quote_bg_color",
      "label": "Quote background",
      "default": "#f9f9f9"
    },
    {
      "type": "color",
      "id": "divider_color",
      "label": "Divider",
      "default": "#e0e0e0"
    }
  ],
  "presets": [
    {
      "name": "Blog post"
    }
  ]
}
{% endschema %}
